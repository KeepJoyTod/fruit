<view class="page register-page">
  <view class="header">
    <text class="title">注册账号</text>
    <text class="subtitle">顾客注册后可以浏览鲜果，摊主还需要填写摊位资料。</text>
  </view>

  <view class="form">
    <input value="{{form.username}}" data-field="username" bindinput="onInput" placeholder="账号" />
    <input value="{{form.password}}" data-field="password" bindinput="onInput" placeholder="密码，至少 6 位" password />
    <input value="{{form.nickname}}" data-field="nickname" bindinput="onInput" placeholder="昵称" />
    <view class="role-row">
      <view class="role {{form.role === 'CUSTOMER' ? 'active' : ''}}" data-role="CUSTOMER" bindtap="changeRole">顾客</view>
      <view class="role {{form.role === 'VENDOR' ? 'active' : ''}}" data-role="VENDOR" bindtap="changeRole">摊主</view>
    </view>

    <view wx:if="{{form.role === 'VENDOR'}}" class="vendor-fields">
      <input value="{{form.stallName}}" data-field="stallName" bindinput="onInput" placeholder="摊位名称" />
      <input value="{{form.phone}}" data-field="phone" bindinput="onInput" placeholder="联系电话" type="number" />
      <input value="{{form.address}}" data-field="address" bindinput="onInput" placeholder="摊位地址" />
      <view class="location-row">
        <input value="{{form.latitude}}" data-field="latitude" bindinput="onInput" placeholder="纬度" type="digit" />
        <input value="{{form.longitude}}" data-field="longitude" bindinput="onInput" placeholder="经度" type="digit" />
      </view>
      <button class="ghost-button" bindtap="chooseLocation">选择摊位位置</button>
    </view>
  </view>

  <button class="primary-button submit" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submit">完成注册</button>
</view>
