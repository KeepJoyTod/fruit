.profile {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-radius: 12rpx;
  background: #ffffff;
}

.profile-summary {
  flex: 1;
}

.profile-actions {
  display: flex;
  gap: 12rpx;
}

.stall {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
}

.address {
  display: block;
  margin-top: 10rpx;
  color: #637166;
  font-size: 24rpx;
}

.setup {
  width: 140rpx;
  margin: 0;
}

.profile-form {
  width: 100%;
}

.profile-form input {
  width: 100%;
  height: 76rpx;
  margin-bottom: 14rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  border: 1rpx solid #d8e2da;
  border-radius: 10rpx;
  background: #fbfcfb;
  font-size: 26rpx;
}

.location-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.profile-form-actions {
  display: grid;
  grid-template-columns: 1fr 1fr 1.2fr;
  gap: 14rpx;
}

.profile-form-actions button {
  margin: 0;
}

.stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 20rpx;
}

.stats view {
  padding: 20rpx 10rpx;
  border-radius: 12rpx;
  background: #ffffff;
  text-align: center;
}

.num {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
}

.label {
  display: block;
  margin-top: 8rpx;
  color: #6d7a70;
  font-size: 22rpx;
}

.add {
  margin-top: 24rpx;
}

.fruit-list {
  margin-top: 24rpx;
}

.fruit-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 18rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #ffffff;
}

.thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  background: #dbe6dc;
}

.thumb-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1f7a4d;
  font-size: 32rpx;
  font-weight: 700;
}

.item-main {
  flex: 1;
}

.fruit-name,
.fruit-price,
.fruit-status {
  display: block;
}

.fruit-name {
  font-size: 30rpx;
  font-weight: 600;
}

.fruit-price {
  margin-top: 8rpx;
  color: #d35400;
}

.fruit-status {
  margin-top: 6rpx;
  color: #6d7a70;
  font-size: 22rpx;
}

.item-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.item-actions button {
  width: 100rpx;
}

.item-actions .danger {
  color: #b42318;
}

.empty {
  margin-top: 60rpx;
  text-align: center;
  color: #7a857d;
}

.empty text {
  display: block;
  margin-bottom: 20rpx;
}
