page {
  min-height: 100vh;
  background: #f6f7f9;
  color: #1f2933;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  box-sizing: border-box;
}

view,
text,
image,
button,
input,
textarea {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.muted {
  color: #7b8794;
}

.primary-button {
  height: 88rpx;
  border-radius: 8rpx;
  background: #16a34a;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 88rpx;
}

.primary-button::after {
  border: 0;
}
