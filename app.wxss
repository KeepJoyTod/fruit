page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff8f1 0%, #fffdf8 32%, #f7fbf5 100%);
  color: #243126;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  box-sizing: border-box;
}

view,
text,
image,
button,
input,
textarea {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.25;
  letter-spacing: 1rpx;
}

.muted {
  color: #7c8b7a;
}

.primary-button {
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #2f9e44 0%, #56b75e 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 88rpx;
  box-shadow: 0 18rpx 36rpx rgba(47, 158, 68, 0.22);
}

.primary-button::after {
  border: 0;
}

.section-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.section-heading-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #243126;
}

.section-heading-copy {
  color: #8d9c8b;
  font-size: 24rpx;
}

.glass-panel {
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 18rpx 48rpx rgba(135, 100, 48, 0.08);
  backdrop-filter: blur(16rpx);
}
