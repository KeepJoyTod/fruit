<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.fruit.management.mapper.FruitImageMapper">
    <resultMap id="FruitImageResultMap" type="com.fruit.management.entity.FruitImageEntity">
        <id column="id" property="id"/>
        <result column="fruit_id" property="fruitId"/>
        <result column="image_url" property="imageUrl"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <insert id="insert" parameterType="com.fruit.management.entity.FruitImageEntity">
        INSERT INTO fruit_images (fruit_id, image_url, sort_order, created_at)
        VALUES (#{fruitId}, #{imageUrl}, #{sortOrder}, #{createdAt})
    </insert>

    <insert id="batchInsert">
        INSERT INTO fruit_images (fruit_id, image_url, sort_order, created_at)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.fruitId}, #{item.imageUrl}, #{item.sortOrder}, #{item.createdAt})
        </foreach>
    </insert>

    <select id="selectByFruitId" resultMap="FruitImageResultMap">
        SELECT * FROM fruit_images WHERE fruit_id = #{fruitId} ORDER BY sort_order ASC
    </select>

    <delete id="deleteByFruitId">
        DELETE FROM fruit_images WHERE fruit_id = #{fruitId}
    </delete>
</mapper>