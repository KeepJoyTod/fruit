.fruit-card {
  display: flex;
  gap: 22rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(122, 92, 44, 0.08);
}

.fruit-media {
  position: relative;
  flex: none;
}

.fruit-image {
  width: 196rpx;
  height: 196rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #fdf3e6 0%, #f3f8ef 100%);
}

.fruit-price-badge {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  bottom: 12rpx;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(36, 49, 38, 0.72);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
}

.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7c8b7a;
  font-size: 24rpx;
}

.fruit-info {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
  flex: 1;
  padding: 8rpx 0;
}

.fruit-name {
  color: #243126;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.45;
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.fruit-shop {
  margin-top: 12rpx;
  color: #7c8b7a;
  font-size: 24rpx;
}

.fruit-desc {
  margin-top: 10rpx;
  color: #97a492;
  font-size: 24rpx;
}

.fruit-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.fruit-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 138, 61, 0.12);
  color: #d46b1f;
  font-size: 22rpx;
  font-weight: 600;
}

.fruit-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
}

.fruit-meta {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f2fbf1;
  color: #2f9e44;
  font-size: 24rpx;
  font-weight: 700;
}

.fruit-cta {
  color: #ff8a3d;
  font-size: 24rpx;
  font-weight: 700;
}
