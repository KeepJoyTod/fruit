.search-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.search-hero {
  padding: 30rpx;
}

.search-title {
  color: #243126;
  font-size: 38rpx;
  font-weight: 700;
}

.search-copy {
  margin-top: 12rpx;
  color: #7c8b7a;
  line-height: 1.7;
}

.search-bar {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.search-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  flex: 1;
  box-shadow: inset 0 0 0 1rpx rgba(47, 158, 68, 0.08);
}

.search-button {
  flex: none;
  width: 140rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #2f9e44 0%, #56b75e 100%);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 88rpx;
  box-shadow: 0 16rpx 32rpx rgba(47, 158, 68, 0.2);
}

.search-button::after {
  border: 0;
}

.preset-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.preset-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 138, 61, 0.12);
  color: #d46b1f;
  font-size: 24rpx;
  font-weight: 700;
}

.search-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 24rpx;
}

.link-button {
  padding: 0;
  color: #2f9e44;
  background: transparent;
  font-size: 26rpx;
}

.link-button::after {
  border: 0;
}

.fruit-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.empty {
  padding: 108rpx 0;
  color: #7c8b7a;
  text-align: center;
}

.placeholder {
  padding: 36rpx 0;
  text-align: center;
}
