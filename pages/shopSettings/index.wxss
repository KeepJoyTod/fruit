.form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 32rpx;
}

.section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
}

.logo-picker {
  width: 180rpx;
  height: 180rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #ffffff;
}

.logo-image,
.logo-placeholder {
  width: 100%;
  height: 100%;
}

.logo-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f766e;
  font-size: 26rpx;
  font-weight: 700;
}

.field,
.textarea {
  width: 100%;
  padding: 24rpx;
  border-radius: 8rpx;
  background: #ffffff;
}

.field {
  height: 88rpx;
}

.textarea {
  min-height: 180rpx;
}

.status-switch {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.status-option {
  height: 76rpx;
  border-radius: 8rpx;
  background: #ffffff;
  color: #52616b;
  font-size: 28rpx;
  line-height: 76rpx;
  text-align: center;
}

.status-option.active {
  background: #0f766e;
  color: #ffffff;
  font-weight: 700;
}
