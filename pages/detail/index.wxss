.detail-page {
  padding-bottom: 184rpx;
}

.gallery-card {
  position: relative;
}

.main-image {
  width: 100%;
  height: 560rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #fdf3e6 0%, #f3f8ef 100%);
  box-shadow: 0 24rpx 48rpx rgba(122, 92, 44, 0.1);
}

.image-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7b8794;
}

.image-count {
  position: absolute;
  right: 24rpx;
  bottom: 108rpx;
  min-width: 92rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.68);
  color: #ffffff;
  font-size: 24rpx;
  text-align: center;
}

.thumb-list {
  margin-top: 16rpx;
  white-space: nowrap;
}

.thumb-item {
  display: inline-flex;
  width: 132rpx;
  height: 132rpx;
  padding: 4rpx;
  margin-right: 16rpx;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.92);
}

.thumb-item.is-active {
  border-color: #2f9e44;
}

.thumb-image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.detail-header {
  margin-top: 32rpx;
}

.card {
  padding: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(122, 92, 44, 0.08);
}

.detail-badge-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.detail-badge {
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 138, 61, 0.14);
  color: #d46b1f;
  font-size: 22rpx;
  font-weight: 700;
}

.detail-shop {
  color: #7c8b7a;
  font-size: 24rpx;
}

.price-row {
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
  margin-top: 18rpx;
}

.price {
  color: #e26d2f;
  font-size: 46rpx;
  font-weight: 800;
}

.price-note {
  padding-bottom: 6rpx;
  color: #8d9c8b;
  font-size: 24rpx;
}

.selected-summary {
  margin-top: 18rpx;
  color: #4b5563;
  line-height: 1.6;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.tag {
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #eef9e8;
  color: #2f9e44;
  font-size: 24rpx;
  line-height: 56rpx;
}

.section {
  margin-top: 40rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
}

.link-button {
  padding: 0;
  color: #2f9e44;
  background: transparent;
  font-size: 26rpx;
}

.link-button::after {
  border: 0;
}

.spec-group {
  margin-bottom: 24rpx;
}

.spec-group-title {
  margin-bottom: 14rpx;
  color: #4b5563;
  font-size: 26rpx;
  font-weight: 700;
}

.spec-value-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.spec-value {
  min-width: 136rpx;
  min-height: 64rpx;
  padding: 14rpx 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #243126;
  font-size: 26rpx;
  text-align: center;
}

.spec-value.is-selected {
  border-color: #2f9e44;
  background: #eef9e8;
  color: #2f9e44;
  font-weight: 700;
}

.spec-value.is-disabled {
  color: #9ca3af;
  background: rgba(243, 244, 246, 0.82);
}

.sku-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 16rpx 36rpx rgba(122, 92, 44, 0.06);
}

.spec-name {
  margin-bottom: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.spec-side {
  flex: none;
  text-align: right;
}

.spec-price {
  margin-bottom: 8rpx;
  color: #dc2626;
  font-weight: 800;
}

.spec-stock.is-out {
  color: #dc2626;
}

.spec-empty {
  margin-top: 0;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-pill {
  min-width: 200rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 16rpx 32rpx rgba(122, 92, 44, 0.06);
}

.category-name {
  font-weight: 700;
}

.category-sub {
  margin-top: 10rpx;
  color: #7b8794;
  font-size: 24rpx;
}

.content-text {
  padding: 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 16rpx 32rpx rgba(122, 92, 44, 0.06);
  line-height: 1.7;
}

.detail-image-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.detail-image {
  width: 100%;
  height: 260rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #fdf3e6 0%, #f3f8ef 100%);
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 250, 245, 0.9);
  box-shadow: 0 -12rpx 32rpx rgba(36, 49, 38, 0.08);
  backdrop-filter: blur(18rpx);
}

.secondary-button {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  color: #243126;
  font-size: 28rpx;
  line-height: 88rpx;
  box-shadow: 0 12rpx 28rpx rgba(122, 92, 44, 0.06);
}

.secondary-button::after {
  border: 0;
}

.share-button {
  flex: 1.2;
}

.placeholder {
  padding: 120rpx 0;
  text-align: center;
}

.empty {
  padding: 120rpx 0;
  text-align: center;
}
