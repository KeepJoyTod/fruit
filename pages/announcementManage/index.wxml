<view class="page announcement-page">
  <view class="page-title">公告编辑</view>

  <view class="announcement-card">
    <view class="card-title">发布给用户看的店铺公告</view>
    <view class="muted card-copy">发布后会在用户首页的“店铺公告”板块展示。</view>
    <textarea
      class="announcement-textarea"
      maxlength="200"
      placeholder="例如：今日新到一批阳光玫瑰，数量有限，先到先得。"
      value="{{announcement}}"
      bindinput="onAnnouncementInput"
    />
    <view class="textarea-meta">
      <view>{{updatedText}}</view>
      <view>{{announcement.length}} / 200</view>
    </view>
  </view>

  <view class="preview-card">
    <view class="card-title">用户端预览</view>
    <view class="preview-notice">
      <view class="preview-icon">告</view>
      <view class="preview-content">
        <view class="preview-title">店铺公告</view>
        <view class="preview-text">{{announcement || '公告发布后，用户会在这里看到内容。'}}</view>
      </view>
    </view>
  </view>

  <view class="action-row">
    <button class="secondary-button clear-button" bindtap="clearDraft">清空</button>
    <button class="primary-button publish-button" loading="{{saving}}" disabled="{{saving}}" bindtap="publish">发布公告</button>
  </view>
</view>
