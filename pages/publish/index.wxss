.form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 32rpx;
}

.field,
.textarea {
  width: 100%;
  padding: 24rpx;
  border-radius: 8rpx;
  background: #ffffff;
}

.field {
  height: 88rpx;
}

.textarea {
  min-height: 180rpx;
}

.image-picker {
  width: 240rpx;
  height: 240rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #ffffff;
}

.preview-image,
.image-placeholder {
  width: 100%;
  height: 100%;
}

.image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #16a34a;
  font-weight: 600;
}

.image-tip {
  font-size: 24rpx;
}

.detail-image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.detail-image-item,
.detail-image-add {
  position: relative;
  width: 152rpx;
  height: 152rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #ffffff;
}

.detail-preview-image {
  width: 100%;
  height: 100%;
}

.detail-image-add {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #16a34a;
  font-size: 24rpx;
  font-weight: 700;
}

.remove-image {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  padding: 0;
  margin: 0;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.72);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 38rpx;
}

.remove-image::after {
  border: 0;
}

.section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  height: 60rpx;
  padding: 0 24rpx;
  border-radius: 8rpx;
  background: #ffffff;
  color: #52606d;
  line-height: 60rpx;
}

.tag.active {
  background: #dcfce7;
  color: #15803d;
  font-weight: 600;
}

.spec-group,
.sku-item {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #eef2f6;
}

.spec-group-head,
.spec-value-row,
.sku-fields {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.spec-name-field,
.spec-value-field {
  flex: 1;
}

.spec-value-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.mini-button {
  flex: none;
  min-width: 112rpx;
  height: 64rpx;
  padding: 0 18rpx;
  border-radius: 8rpx;
  background: #ffffff;
  color: #52606d;
  font-size: 24rpx;
  line-height: 64rpx;
}

.mini-button.danger {
  color: #dc2626;
}

.mini-button::after {
  border: 0;
}

.secondary-button.compact {
  height: 68rpx;
  font-size: 26rpx;
  line-height: 68rpx;
}

.sku-name {
  font-weight: 700;
}

.sku-field {
  flex: 1;
  min-width: 0;
}

.sku-code-field {
  flex: 1.4;
  min-width: 0;
}

.secondary-button {
  height: 80rpx;
  border-radius: 8rpx;
  background: #ffffff;
  color: #16a34a;
  font-size: 28rpx;
  line-height: 80rpx;
}

.secondary-button::after {
  border: 0;
}
